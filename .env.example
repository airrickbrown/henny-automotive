# Copy this file to .env.local for local overrides
# Set this in your Vercel / Netlify environment variables for production

# The canonical URL of the deployed site — used for OG image absolute URLs and canonical links
VITE_SITE_URL=https://hennyautomotive.com

# Supabase — Project URL and anon/public key (safe to expose in browser bundles)
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare Turnstile — CAPTCHA for public forms (optional; forms work without it)
# Get keys at: https://dash.cloudflare.com → Turnstile → Add site
# VITE_TURNSTILE_SITE_KEY is public (safe in frontend). The secret key goes in
# Supabase Edge Function Secrets as TURNSTILE_SECRET_KEY (never commit it here).
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key-here
